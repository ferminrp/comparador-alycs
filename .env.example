# Variables de entorno para el comparador ALYC.
# Copiá este archivo a .env.local y completá los valores.

# Formulario de contacto (Telegram)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Autenticación con X (Twitter) — NextAuth v5
# Creá una app en https://developer.x.com/ con OAuth 2.0
AUTH_SECRET=
AUTH_TWITTER_ID=
AUTH_TWITTER_SECRET=
# En producción, opcional si usás trustHost: true en auth.ts
# AUTH_URL=https://tu-dominio.com

# Reseñas — Upstash Redis
# Creá una base en https://console.upstash.com/
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
